{
  "name": "personal-oracle",
  "version": "1.0.0",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "cd server && node index.js",
    "dev:client": "cd client && npm run dev",
    "dev:training-log": "cd apps/training-log && npm run dev",
    "dev:pre-game": "cd apps/pre-game && npm run dev",
    "dev:debt-assassination": "cd apps/debt-assassination && npm run dev",
    "build": "cd client && npm install && npm run build",
    "build:training-log": "cd apps/training-log && npm run build",
    "build:pre-game": "cd apps/pre-game && npm run build",
    "build:debt-assassination": "cd apps/debt-assassination && npm run build",
    "install:all": "npm install && cd server && npm install && cd ../client && npm install && cd ../apps/training-log && npm install && cd ../pre-game && npm install && cd ../debt-assassination && npm install"
  },
  "dependencies": {
    "@clerk/express": "^1.3.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "pg": "^8.11.5",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "sharp": "^0.34.5"
  }
}
